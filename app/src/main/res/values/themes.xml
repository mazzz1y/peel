<resources>

    <style name="AppTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorOnPrimary">@color/brand_onPrimary</item>
        <item name="colorPrimaryContainer">@color/brand_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/brand_onPrimaryContainer</item>
        <item name="colorSecondary">@color/brand_secondary</item>
        <item name="colorOnSecondary">@color/brand_onSecondary</item>
        <item name="colorSecondaryContainer">@color/brand_secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/brand_onSecondaryContainer</item>
        <item name="colorTertiary">@color/brand_tertiary</item>
        <item name="colorOnTertiary">@color/brand_onTertiary</item>
        <item name="colorTertiaryContainer">@color/brand_tertiaryContainer</item>
        <item name="colorOnTertiaryContainer">@color/brand_onTertiaryContainer</item>
        <item name="colorError">@color/brand_error</item>
        <item name="colorOnError">@color/brand_onError</item>
        <item name="colorErrorContainer">@color/brand_errorContainer</item>
        <item name="colorOnErrorContainer">@color/brand_onErrorContainer</item>
        <item name="android:colorBackground">@color/brand_background</item>
        <item name="colorOnBackground">@color/brand_onBackground</item>
        <item name="colorSurface">@color/brand_surface</item>
        <item name="colorOnSurface">@color/brand_onSurface</item>
        <item name="colorSurfaceVariant">@color/brand_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/brand_onSurfaceVariant</item>
        <item name="colorOutline">@color/brand_outline</item>
        <item name="colorOutlineVariant">@color/brand_outlineVariant</item>
        <item name="colorSurfaceInverse">@color/brand_inverseSurface</item>
        <item name="colorOnSurfaceInverse">@color/brand_inverseOnSurface</item>
        <item name="colorPrimaryInverse">@color/brand_inversePrimary</item>
        <item name="colorSurfaceDim">@color/brand_surfaceDim</item>
        <item name="colorSurfaceBright">@color/brand_surfaceBright</item>
        <item name="colorSurfaceContainerLowest">@color/brand_surfaceContainerLowest</item>
        <item name="colorSurfaceContainerLow">@color/brand_surfaceContainerLow</item>
        <item name="colorSurfaceContainer">@color/brand_surfaceContainer</item>
        <item name="colorSurfaceContainerHigh">@color/brand_surfaceContainerHigh</item>
        <item name="colorSurfaceContainerHighest">@color/brand_surfaceContainerHighest</item>
        <item name="android:windowBackground">?attr/colorSurfaceContainerLow</item>
        <item name="popupMenuBackground">@drawable/popup_menu_background_rounded</item>
    </style>

    <style name="AppTheme.Launcher">
        <item name="android:windowBackground">@drawable/launch_screen</item>
    </style>

    <style name="AppTheme.Transparent" parent="AppTheme">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>

    <style name="AppTheme.Trampoline" parent="AppTheme">
        <item name="android:windowDisablePreview">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>

    <style name="AppTheme.Browser" parent="AppTheme" />

    <style name="ShapeAppearance.App.CircleImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="SettingsItemContainer">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
    </style>

    <style name="SettingsRow.Inline" parent="SettingsItemContainer">
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:minHeight">56dp</item>
    </style>

    <style name="Widget.App.IconButton" parent="Widget.Material3.Button.IconButton">
        <item name="iconTint">?attr/colorOnSurfaceVariant</item>
        <item name="iconSize">24dp</item>
    </style>

    <style name="SettingsIconButton" parent="Widget.App.IconButton" />

    <style name="Widget.App.FloatingIconButton" parent="Widget.AppCompat.ImageButton">
        <item name="android:layout_width">@dimen/floating_controls_button_size</item>
        <item name="android:layout_height">@dimen/floating_controls_button_size</item>
        <item name="android:background">?attr/selectableItemBackgroundBorderless</item>
        <item name="android:scaleType">centerInside</item>
        <item name="android:padding">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="tint">?attr/colorOnSurface</item>
    </style>

</resources>
