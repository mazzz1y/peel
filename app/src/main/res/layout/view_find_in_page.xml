<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/find_in_page_bg"
    android:elevation="@dimen/find_in_page_elevation"
    android:gravity="center_vertical"
    android:minHeight="@dimen/find_in_page_min_height"
    android:orientation="horizontal"
    android:paddingStart="12dp"
    android:paddingTop="4dp"
    android:paddingEnd="4dp"
    android:paddingBottom="4dp">

    <EditText
        android:id="@+id/findInPageQuery"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="@null"
        android:hint="@string/find_in_page_hint"
        android:imeOptions="actionSearch|flagNoExtractUi"
        android:importantForAutofill="no"
        android:inputType="text"
        android:maxLines="1"
        android:singleLine="true"
        android:textAppearance="?attr/textAppearanceBodyLarge"
        android:textColor="?attr/colorOnSurface"
        android:textColorHint="?attr/colorOnSurfaceVariant"
        tools:ignore="LabelFor" />

    <TextView
        android:id="@+id/findInPageCounter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="12dp"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:textColor="?attr/colorOnSurfaceVariant"
        tools:text="3 / 17" />

    <ImageButton
        android:id="@+id/findInPagePrev"
        style="@style/Widget.App.FloatingIconButton"
        android:contentDescription="@string/find_in_page_prev"
        android:src="@drawable/ic_symbols_keyboard_arrow_up_24" />

    <Space
        android:layout_width="@dimen/find_in_page_button_gap"
        android:layout_height="match_parent" />

    <ImageButton
        android:id="@+id/findInPageNext"
        style="@style/Widget.App.FloatingIconButton"
        android:contentDescription="@string/find_in_page_next"
        android:src="@drawable/ic_symbols_keyboard_arrow_down_24" />

    <Space
        android:layout_width="@dimen/find_in_page_button_gap"
        android:layout_height="match_parent" />

    <ImageButton
        android:id="@+id/findInPageClose"
        style="@style/Widget.App.FloatingIconButton"
        android:contentDescription="@string/find_in_page_close"
        android:src="@drawable/ic_symbols_close_24" />

</LinearLayout>
