<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="@dimen/floating_controls_button_size"
    android:layout_height="@dimen/floating_controls_button_size"
    app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
    app:cardCornerRadius="@dimen/floating_controls_corner_radius"
    app:cardElevation="@dimen/floating_controls_elevation"
    app:contentPadding="0dp"
    app:strokeWidth="0dp">

    <ImageView
        android:id="@+id/floatingTriggerIconMenu"
        android:layout_width="@dimen/floating_controls_button_size"
        android:layout_height="@dimen/floating_controls_button_size"
        android:contentDescription="@null"
        android:scaleType="centerInside"
        android:src="@drawable/ic_symbols_menu_24"
        app:tint="?attr/colorOnSurface" />

    <ImageView
        android:id="@+id/floatingTriggerIconClose"
        android:layout_width="@dimen/floating_controls_button_size"
        android:layout_height="@dimen/floating_controls_button_size"
        android:alpha="0"
        android:contentDescription="@null"
        android:scaleType="centerInside"
        android:src="@drawable/ic_symbols_close_24"
        app:tint="?attr/colorOnSurface" />

</com.google.android.material.card.MaterialCardView>
