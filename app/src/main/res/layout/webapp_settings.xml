<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".activities.WebAppSettingsActivity">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="@dimen/margin_activity"
            android:layout_marginBottom="@dimen/margin_activity"
            android:fadeScrollbars="true"
            android:fillViewport="true"
            android:isScrollContainer="true"
            android:scrollbarFadeDuration="300"
            android:scrollbarStyle="outsideOverlay">

            <LinearLayout
                android:id="@+id/contentContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_activity"
                android:layout_marginEnd="@dimen/margin_activity"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/sectionMainSettings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <include layout="@layout/include_settings_icon_title_url" />

                    <LinearLayout
                        android:id="@+id/groupRow"
                        style="@style/SettingsRow.Inline"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/group"
                            android:textAppearance="?attr/textAppearanceBodyLarge" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnGroupPicker"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/ungrouped" />

                    </LinearLayout>

                    <View
                        android:id="@+id/groupDivider"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="@dimen/settings_item_padding_vertical"
                        android:background="?attr/colorOutlineVariant"
                        android:visibility="gone" />

                    <include layout="@layout/include_settings_sandbox_rows" />

                </LinearLayout>

                <include layout="@layout/include_settings_override_section" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</layout>
