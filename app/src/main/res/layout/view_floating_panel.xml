<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="@dimen/floating_controls_button_size"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
    app:cardCornerRadius="@dimen/floating_controls_corner_radius"
    app:cardElevation="@dimen/floating_controls_elevation"
    app:contentPadding="0dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:id="@+id/floatingPanelActions"
        android:layout_width="@dimen/floating_controls_button_size"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="@dimen/floating_controls_panel_padding"
        android:paddingBottom="@dimen/floating_controls_panel_padding" />

</com.google.android.material.card.MaterialCardView>
