{
  "manifest_version": 2,
  "name": "Page Info",
  "version": "12",
  "browser_specific_settings": {
    "gecko": {
      "id": "peel@mazy.wtf"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "<all_urls>",
    "geckoViewAddons",
    "nativeMessaging",
    "nativeMessagingFromContent"
  ]
}
